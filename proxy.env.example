# Copy this file to .env and fill in the provider key(s) you want.
# Then load variables into your shell before running proxy_server.py

# OpenAI
OPENAI_API_KEY=
OPENAI_API_ENDPOINT=https://api.openai.com/v1/chat/completions

# Ollama local AI (no API key required)
# Install Ollama, then run: ollama pull llama3.2:3b
OLLAMA_API_ENDPOINT=http://127.0.0.1:11434/api/chat

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_API_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_HTTP_REFERER=http://localhost
OPENROUTER_APP_TITLE=Chemistry Fundamentals 007

# Custom OpenAI-compatible provider
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_API_ENDPOINT=

# Proxy host/port
# Use 0.0.0.0 if you want iPhone/iPad devices on your home Wi-Fi to open the app.
PROXY_HOST=127.0.0.1
PROXY_PORT=5051
